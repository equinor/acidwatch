{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Backend",
            "type": "shell",
            "command": "poetry",
            "args": ["run", "uvicorn", "acidwatch_api.app:app,", "--host", "0.0.0.0","--port","8000"],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            }
        },
         {
            "label": "Run Frontend",
            "type": "shell",
            "command": "npm run dev",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            }
        },
    ]
}